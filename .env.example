# Postgres
DATABASE_URL="postgresql://user:pass@localhost:5432/eventlifter?schema=public"

# Redis (BullMQ queues)
REDIS_URL="redis://localhost:6379"

# Eventbrite OAuth app (for the connect flow; per-host tokens live in the DB)
EVENTBRITE_CLIENT_ID=""
EVENTBRITE_CLIENT_SECRET=""
EVENTBRITE_REDIRECT_URI="https://api.eventlifter.com/connections/eventbrite/callback"

# Encryption key for channel_connections.credentials (envelope encryption / KMS data key)
CREDENTIALS_KMS_KEY=""

# Luma keys are per-host and stored (encrypted) in channel_connections, not here.
